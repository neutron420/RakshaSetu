# user-be – copy to .env and fill values
NODE_ENV=development
USER_BE_PORT=5001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rakshasetu?schema=public
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# R2 Storage (presigned uploads + public URL)
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=rakshasetu-media
R2_PUBLIC_DOMAIN=

# Kafka (set KAFKA_ENABLED=true to enable; default false)
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=rakshasetu-user-be
KAFKA_ENABLED=false

# Optional
EXPO_ACCESS_TOKEN=
SMS_PROVIDER_API_KEY=

# AWS Credentials for Voice Bot
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
