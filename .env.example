# RakshaSetu – root .env (used by prisma.config.ts for migrations)
NODE_ENV=development
USER_BE_PORT=5001
# PostgreSQL connection string (use same DB name as user-be for consistency)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rakshasetu?schema=public

# JWT (user-be)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Cloudflare R2 (S3-compatible) – user-be media uploads
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=rakshasetu-media
# Public URL base for stored files (e.g. custom domain); set in production
R2_PUBLIC_DOMAIN=

# Optional: push notifications (Expo), SMS (e.g. Twilio / MSG91)
EXPO_ACCESS_TOKEN=
SMS_PROVIDER_API_KEY=
